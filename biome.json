{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/bin",
			"!**/obj",
			"!data",
			"!**/__pycache__",
			"!**/.venv",
			"!**/venv",
			"!**/env",
			"!**/.env",
			"!**/virtualenv"
		]
	},
	"formatter": {
		"indentStyle": "tab"
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	},
	"css": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		}
	}
}
