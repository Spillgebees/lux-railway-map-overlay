# Development container for the Blazor viewer.
#
# This image is intended for bind-mounted local development, not production.
# Mount the repository at /workspace/lux-railway-map-overlay. The viewer uses
# the packaged Spillgebees.Blazor.Map dependency declared in RailwayViewer.csproj.

FROM mcr.microsoft.com/dotnet/sdk:10.0@sha256:ea8bde36c11b6e7eec2656d0e59101d4462f6bd630730f2c8201ed0572b295d5

WORKDIR /workspace/lux-railway-map-overlay/viewer

ENV ASPNETCORE_URLS=http://0.0.0.0:8080
ENV DOTNET_USE_POLLING_FILE_WATCHER=1

EXPOSE 8080

CMD ["dotnet", "watch", "run", "--urls", "http://0.0.0.0:8080"]
